# DimaruBot Environment Configuration
# Copy this file to .env and fill in real values.

# Node
NODE_ENV=development

# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_CLIENT_SECRET=your_discord_oauth_secret

# Database
DATABASE_URL=postgresql://dmb:password@localhost:5432/dimarubot

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_to_a_random_32_char_string
JWT_REFRESH_SECRET=change_me_to_a_different_random_32_char_string

# AI
OPENAI_API_KEY=your_openai_key

# Economy
ECONOMY_HMAC_SECRET=change_me_to_a_random_64_char_string

# Admin
GOD_MODE_USER_IDS=1228369441683931149

# API / Dashboard
API_PORT=3001
DASHBOARD_PORT=3000
API_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3000
