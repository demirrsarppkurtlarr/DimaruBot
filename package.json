{
  "name": "dimarubot",
  "version": "0.1.0",
  "private": true,
  "description": "DimaruBot — AI-powered modular Discord platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:migrate": "turbo run db:migrate",
    "db:deploy": "turbo run db:deploy",
    "db:generate": "turbo run db:generate",
    "db:studio": "turbo run db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "modules/*"
  ],
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
